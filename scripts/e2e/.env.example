# Copy this file to `scripts/e2e/.env` for local manual E2E runs.
#
# These keys are used only by `npm run test:e2e:real`.
# The real `scripts/e2e/.env` file is ignored by Git.

GROQ_API_KEY=
OPENROUTER_API_KEY=
AI_GATEWAY_API_KEY=

# Optional provider selection:
# E2E_REAL_PROVIDERS=groq,openrouter,vercel

# Optional model overrides:
# E2E_GROQ_MODEL=openai/gpt-oss-20b
# E2E_OPENROUTER_MODEL=openai/gpt-4.1-nano
# E2E_VERCEL_MODEL=openai/gpt-5-nano

# Keep temp artifacts from the packed-install E2E run for inspection:
# E2E_KEEP_ARTIFACTS=1
